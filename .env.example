# =============================================================================
# Banco POS — environment. Copy to `.env` and adjust. These defaults stand up a
# working local single-host stack as-is (docker compose up). Everything marked
# 🔒 CHANGE must be replaced with your own value before any network-exposed use.
#
#   cp .env.example .env
#
# The values below intentionally point at the compose service names
# (postgres / keycloak / minio) — they work unchanged for `docker compose up`.
# =============================================================================

# --- Environment / branding -------------------------------------------------
HX_ENVIRONMENT=LOCAL
PROJECT_NAME=Banco POS
PROJECT_APP_VERSION=1.0.0
API_VERSION=1.0.0
API_V1_STR=/api/v1
OPENAPI_URL=/openapi.json
DOCS_URL=/docs

# --- App host / ports -------------------------------------------------------
# APP_PORT is the port INSIDE the container (the app always binds 8000 — leave it).
# *_HOST_PORT vars below are the localhost ports Docker publishes to — change THOSE
# if something else already uses a port on your machine.
APP_HOST=0.0.0.0
APP_PORT=8000
APP_HOST_PORT=8000
FASTAPI_BASE_URL=http://localhost:8000
# 🔒 CHANGE — app signing secret. Generate: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# First boot with demo catalog + staff (true) OR an empty shop you'll restore
# real data into (false). Staff/store-settings seed either way, so a user can
# log in and VAT is correct. Set false when you plan to restore a B2 backup.
HX_SEED_DEMO=true

# --- Postgres ---------------------------------------------------------------
# POSTGRES_PORT = in-network port the app dials (leave 5432).
# POSTGRES_HOST_PORT = localhost port for your own psql access (change if 5432 is busy).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_DB=helix_db
POSTGRES_TEST_DB=helix_test
POSTGRES_USER=helix_user
# 🔒 CHANGE for anything beyond a laptop
POSTGRES_PASSWORD=banco_local_dev

# --- Keycloak (server-to-server: token validation, JWKS, admin) -------------
# The in-network URL the APP uses to reach Keycloak. Leave as the service name.
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_HELIX_REALM_INTERNAL_URL=http://keycloak:8080
KC_HOSTNAME=keycloak
KC_HTTP_PORT=8080
KC_HOST_PORT=8080
KC_HOSTNAME_ADMIN_URL=http://localhost:8080
KC_EXTERNAL_URL=http://localhost:8080
KEYCLOAK_EXTERNAL_URL=http://localhost:8080

# The realm POS actually validates against (matches keycloak/import/realm-export.json).
POS_REALM=kc-pos-realm-dev
KEYCLOAK_REALM=kc-pos-realm-dev
KEYCLOAK_DEV_REALM=kc-pos-realm-dev
KEYCLOAK_MASTER_REALM=master

# POS login client is PUBLIC (no secret on the login path). These are unused by
# the POS login flow but must be present for the settings to load — leave blank.
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_SERVICE_CLIENT_SECRET=

# Keycloak master admin — MUST match the KEYCLOAK_ADMIN(_PASSWORD) below and the
# compose keycloak service. The app uses these for its KC health/admin calls.
HX_SUPER_NAME=admin
# 🔒 CHANGE for anything beyond a laptop
HX_SUPER_PASSWORD=banco_local_dev
HX_SUPER_EMAIL=admin@example.com
KEYCLOAK_ADMIN_PASSWORD=banco_local_dev

# --- Keycloak (BROWSER-facing) ----------------------------------------------
# The origin the USER's browser is redirected to for login. For a single local
# host this is localhost:8080. Empty = fall back to the built-in host logic
# (prod hosts). This is the one browser-vs-server split — keep it set locally.
POS_KC_PUBLIC_URL=http://localhost:8080

# --- PRODUCTION: public domain + HTTPS --------------------------------------
# Empty for local. Run `python3 scripts/go-live.py` to fill these + generate the
# ./Caddyfile reverse-proxy config. Deploy with `./scripts/deploy-prod.sh`.
# BANCO_ENV drives the subdomain prefix + safety: local | sandbox | production.
BANCO_ENV=local
# APP_PUBLIC_HOST — the shop's address, e.g. banco.wolfhold.app
APP_PUBLIC_HOST=
# KC_PUBLIC_HOST — Keycloak's address, e.g. banco-auth.wolfhold.app
KC_PUBLIC_HOST=
# ACME_EMAIL — Let's Encrypt contact (Caddy emails cert-renewal warnings here)
ACME_EMAIL=

# --- Email via Resend (Keycloak password resets + staff setup links) --------
# Resend (resend.com): make an API key, verify your sending domain (adds DKIM/SPF
# records at your registrar — same place as the A record). Empty = no email
# (local dev uses MailHog instead). SMTP_PASSWORD is your Resend API key (re_...).
# NOTE: keep comments on their OWN lines — an inline `# ...` after a value is read
# as part of the value by the .env parsers (and a secret may legitimately contain #).
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=
# SMTP_FROM — a verified Resend domain, e.g. noreply@lapiazza.app
SMTP_FROM=
SMTP_FROM_NAME=Banco

# --- Backup alerting (dead-man's switch) ------------------------------------
# Optional but recommended for prod: a healthchecks.io check URL. backup-to-b2.sh
# pings it on every successful run — if a nightly backup silently stops, healthchecks
# emails/alerts YOU. A backup you don't know has stopped is not a backup.
HEALTHCHECK_PING_URL=

# --- Postcard campaign QR tracker (optional; only if you mail the head-shop cards) ---
# GET /r/{token} logs the scan (append-only JSONL) and redirects the prospect to your demo.
# Default = the app's own /pos (same host, no config). Set an absolute URL to send scans to a
# specific demo surface — e.g. the guest kiosk: https://banco.<yourdomain>/pos/kiosk
POSTCARD_REDIRECT_URL=

# --- MinIO (image / artifact store: snap-fill, OG cards) --------------------
# MINIO_PORT = in-network port the app dials (leave 9000). *_HOST_PORT = localhost access.
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_BUCKET=helix-artifacts
MINIO_ACCESS_KEY=helix_user
# 🔒 CHANGE for anything beyond a laptop
MINIO_SECRET_KEY=banco_local_dev

# --- POS behavior -----------------------------------------------------------
POS_CURRENCY=CHF
POS_LOCALE=de-CH
POS_VAT_RATE=8.1
POS_VAT_RATE_REDUCED=2.6
POS_VAT_YEAR=2025

# --- BYO-brain (optional LLM for snap-fill / enrich / teasers) --------------
# Leave blank to run without an LLM (those features degrade, POS is unaffected).
# Set your Ollama Turbo key, or point OLLAMA_URL at a local Ollama.
BH_OLLAMA_KEY=
OLLAMA_TURBO_URL=
OLLAMA_URL=http://ollama:11434

# --- Present only to satisfy settings loading (NOT on the /pos request path) -
# The minimal profile does not run redis/rabbitmq/vault. Values are placeholders.
REDIS_HOST=redis
REDIS_PORT=6379
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=helix_user
RABBITMQ_PASS=banco_local_dev
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=local-dev-token
VAULT_DEV_ROOT_TOKEN_ID=local-dev-token
VAULT_DEV_LISTEN_ADDRESS=0.0.0.0:8200

# =============================================================================
# Backblaze B2 — for scripts/restore-from-b2.sh (own-your-data / DR path).
# These are NOT needed to run the app. Fill them only when restoring a backup.
# For RESTORE (restore-from-b2.sh): a read-only key (listFiles+readFiles) is enough.
# For MAKING backups (backup-to-b2.sh): the key needs write access (writeFiles).
# Best practice = two keys: a write key on the shop machine, a read key kept for recovery.
# See onboarding/06-own-your-data-backups.md.
# =============================================================================
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_BUCKET_ID=
# Passphrase for the encrypted backup file (.sql.gz.gpg). Handed to you with the key.
BACKUP_GPG_PASSPHRASE=
