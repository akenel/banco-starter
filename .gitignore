# Secrets — NEVER commit a real .env
.env
*.env.local

# Personalized onboarding copies that may hold real passwords/keys — keep out of git
*.local.md
*.filled.md

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Backups / data pulled locally (restore-from-b2.sh works in a /tmp mktemp dir,
# so no loose .sql lands here; do NOT blanket-ignore *.sql — it hides the source
# SQL under scripts/db/ that the stand-up needs).
*.sql.gz
*.sql.gz.gpg
*.dump

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
